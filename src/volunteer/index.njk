---
title: "Volunteer"
description: "Volunteer with the ISC2 Tampa Bay Chapter. Explore opportunities to give back, earn CPEs, and grow your career."
layout: base.njk
---

  <!-- Page Header -->
  <div class="page-header">
    <div class="container">
      <h1>Volunteer</h1>
      <p class="page-header-subtitle">Help out, earn CPEs, meet people.</p>
    </div>
  </div>

  <!-- Volunteer Intro -->
  <section class="split-section">
    <div class="container split-grid">
      <div class="split-text">
        <span class="section-label">Get Involved</span>
        <h2>Why Volunteer?</h2>
        <p>Volunteering is the fastest way to get involved. You earn CPE credits, pick up experience you can't get from a textbook, and meet people across the Tampa Bay security scene.</p>
        <p>You don't need to be an ISC2 member. If you want to help, we want you.</p>
      </div>
      <div class="split-media">
        <img src="/images/meeting1.jpeg" alt="ISC2 Tampa Bay volunteers" style="border-radius:var(--radius-lg);box-shadow:var(--shadow-md);">
      </div>
    </div>
  </section>

  <!-- Volunteer Roles -->
  <section class="content-section" style="background: var(--light-gray);">
    <div class="container">
      <div class="section-heading">
        <span class="section-label">Opportunities</span>
        <h2>Volunteer Roles</h2>
      </div>
      <div class="volunteer-grid">
        {% for role in volunteerRoles %}
        <div class="volunteer-card animate-on-scroll">
          <h3>{{ role.name }}</h3>
          <p>{{ role.description }}</p>
          <span class="volunteer-commitment">{{ role.commitment }}</span>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- Express Interest -->
  <section class="content-section">
    <div class="container">
      <span class="section-label">Apply</span>
      <h2>Express Your Interest</h2>
      <p>Ready to get involved? Fill out the form below and a board member will follow up with you about next steps.</p>
      <div class="form-wrapper">
        <iframe src="https://docs.google.com/forms/d/e/1FAIpQLScdKH7CBjzxMgRromAOQzurYz9eRqvw321O37u0xN0M3CRjqQ/viewform?embedded=true" title="Volunteer Interest Form" width="100%" height="900" frameborder="0">Loading&hellip;</iframe>
      </div>
    </div>
  </section>
