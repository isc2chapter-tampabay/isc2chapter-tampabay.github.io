  <!-- Announcement Bar -->
  <div class="announcement-bar">
    <div class="container">
      <a href="/scholarships/">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        <strong>B &amp; B Cyber Solutions Scholarship:</strong> Two $500 awards for cybersecurity students. You must be present at BSides Tampa to win! Apply by April 1.
        <span class="announcement-arrow">→</span>
      </a>
    </div>
  </div>

  <!-- Header -->
  <header class="site-header">
    <div class="container">
      <a href="/" class="logo">
        <img src="{{ site.logo }}" alt="{{ site.name }} Chapter">
      </a>
      <nav class="main-nav" id="mainNav">
        <button class="nav-toggle" aria-label="Toggle navigation" onclick="document.getElementById('mainNav').classList.toggle('open')">
          <svg width="28" height="28" viewBox="0 0 24 24" aria-hidden="true"><path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z"/></svg>
        </button>
        <ul>
          {%- for item in navigation %}
          <li><a href="{{ item.url }}"{% if item.url === "/scholarships/" %} class="nav-scholarship{% if page.url === item.url %} active{% endif %}"{% elif page.url === item.url %} class="active"{% endif %}>{{ item.label }}</a></li>
          {%- endfor %}
        </ul>
        <a href="/membership/" class="nav-cta">Become a Member</a>
      </nav>
    </div>
  </header>

  <script>
    // Close mobile menu when a nav link is tapped
    document.querySelectorAll('.main-nav a:not(.nav-toggle)').forEach(function(link) {
      link.addEventListener('click', function() {
        document.getElementById('mainNav').classList.remove('open');
      });
    });
  </script>
