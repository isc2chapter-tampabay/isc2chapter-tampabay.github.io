  <!-- Scholarship Overview -->
  <section class="content-section">
    <div class="container">
      <span class="section-label">BSides Tampa 2026</span>
      <h2>B &amp; B Cyber Solutions Scholarship</h2>
      <p><strong>B &amp; B Cyber Solutions</strong> will award two <strong>$500 scholarships</strong> to students pursuing careers in Cybersecurity or Information Technology (IT). These scholarships are intended to encourage emerging talent and help recipients take meaningful steps toward a stable, impactful career in the digital world. Funds may be used for any educational or certification expenses.</p>

      <div class="scholarship-highlights">
        <div class="scholarship-highlight-card">
          <div class="scholarship-highlight-number">2</div>
          <div class="scholarship-highlight-label">Scholarships Available</div>
        </div>
        <div class="scholarship-highlight-card">
          <div class="scholarship-highlight-number">$500</div>
          <div class="scholarship-highlight-label">Each Award</div>
        </div>
        <div class="scholarship-highlight-card">
          <div class="scholarship-highlight-number">Apr 1</div>
          <div class="scholarship-highlight-label">Application Deadline</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Eligibility -->
  <section class="content-section" style="background: var(--light-gray);">
    <div class="container">
      <span class="section-label">Who Can Apply</span>
      <h2>Eligibility Requirements</h2>
      <ul class="benefits-list">
        <li><strong>Field of Study:</strong> Pursuing a degree in <strong>Cybersecurity</strong> or <strong>Information Technology (IT)</strong></li>
        <li><strong>Academic Level:</strong> High school seniors; college freshmen, sophomores, or juniors</li>
        <li><strong>Minimum GPA:</strong> 3.0 cumulative</li>
        <li><strong>Age:</strong> Open to applicants of all ages who meet the academic level criteria</li>
      </ul>

      <div class="callout">
        <p style="margin:0;"><strong>Conference Attendance:</strong> All applicants must be present at <a href="https://bsidestampa.net">BSides Tampa</a> on <strong>May 16, 2026</strong> at the USF Marshall Student Center. Scholarship winners will be announced during the conference closing remarks. Winners must be present in person to receive the scholarship.</p>
      </div>
    </div>
  </section>

  <!-- How to Apply -->
  <section class="content-section">
    <div class="container">
      <span class="section-label">How to Apply</span>
      <h2>Application Materials</h2>
      <p>Prepare the following and submit them as a single packet:</p>
      <ol>
        <li><strong>Transcript</strong>: One of the following:
          <ul>
            <li>A current unofficial high school transcript showing your full name and the name of the high school; or</li>
            <li>A current unofficial college transcript showing your full name, the current academic term, the name of the institution, and areas of study</li>
          </ul>
        </li>
        <li><strong>LinkedIn Profile</strong>: URL to a LinkedIn profile that includes a clear profile photo</li>
        <li><strong>Two-page essay</strong>: Describe how a degree in Cybersecurity or Information Technology (IT) will influence you, change your family's trajectory, and impact your community</li>
      </ol>

      <div class="callout">
        <p style="margin:0 0 8px;"><strong>Email your complete application to:</strong></p>
        <p style="margin:0 0 8px;"><a href="mailto:scholarship@bbcybersolutions.com">scholarship@bbcybersolutions.com</a></p>
        <p style="margin:0;"><strong>Subject line:</strong> B &amp; B Cyber Solutions Scholarship Application [Your Full Name]</p>
      </div>

      <div class="callout" style="border-left-color: #e05555; background: #fff5f5;">
        <p style="margin:0;"><strong>Deadline:</strong> April 1, 2026 at 11:59 PM EST</p>
      </div>
    </div>
  </section>

  <!-- Selection Criteria -->
  <section class="content-section" style="background: var(--light-gray);">
    <div class="container">
      <span class="section-label">Selection</span>
      <h2>How Winners Are Chosen</h2>
      <ul>
        <li>Academic standing</li>
        <li>Quality and clarity of the essay</li>
        <li>Demonstrated commitment to Cybersecurity or Information Technology (IT)</li>
        <li>Professionalism of the LinkedIn profile and supporting documents</li>
      </ul>
      <p>Winners will be notified at BSides Tampa and must be present at the conference to accept the award.</p>
    </div>
  </section>

